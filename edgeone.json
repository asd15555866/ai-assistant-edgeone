{
  "name": "ai-assistant",
  "version": "1.0.0",
  "description": "AI 智能助手 - 自动识别任务类型并分流执行的智能化系统",
  "framework": "react",
  "buildCommand": "cd frontend && npm run build",
  "installCommand": "cd frontend && npm install",
  "outputDirectory": "frontend/dist",
  "nodeVersion": "22.11.0",
  "cloudFunctions": {
    "nodejs": {
      "includeFiles": ["_shared/**"],
      "maxDuration": 60
    }
  },
  "agents": {
    "dir": "agents",
    "framework": "openai",
    "timeout": 300,
    "sandbox": {
      "timeout": 600
    }
  },
  "schedules": [],
  "headers": [
    {
      "source": "/assets/*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "max-age=31536000, immutable"
        }
      ]
    }
  ],
  "env": {
    "JWT_SECRET": "@JWT_SECRET",
    "AI_GATEWAY_BASE_URL": "@AI_GATEWAY_BASE_URL",
    "AI_GATEWAY_API_KEY": "@AI_GATEWAY_API_KEY",
    "AI_MODEL": "deepseek-chat",
    "KV_NAMESPACE": "AI_ASSISTANT_KV",
    "NOTIFICATION_EMAIL": "",
    "DEFAULT_TIMEOUT_MS": "30000",
    "CRON_SCAN_INTERVAL": "60",
    "CRON_SECRET": "@CRON_SECRET"
  }
}
