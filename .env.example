# ============================================
# AI Assistant - 环境变量配置
# ============================================
# 使用方法：
#   1. 复制此文件为 .env（本地开发）或直接在 EdgeOne 控制台设置（生产）
#   2. 所有 @ 开头的变量名（如 @JWT_SECRET）需在 EdgeOne 控制台添加为 Secret
#   3. 非敏感变量（如 AI_MODEL）可直接在 edgeone.json 的 env 中设置默认值
# ============================================

# ==================== 必填配置 ====================

# JWT 签名密钥（必须修改为随机字符串，生产环境使用长随机值）
# 关联：middleware.js 中的 createJWT/verifyJWT
JWT_SECRET=your-super-secret-key-change-this

# Cron 触发器鉴权 Token（防止未授权外部调用消耗沙箱额度）
# 关联：cloud-functions/cron-trigger.ts 中的 Token 鉴权
CRON_SECRET=generate-a-random-secret-token-here

# ==================== AI 模型配置 ====================

# EdgeOne AI_GATEWAY_BASE_URL（二选一）
# 方式一：使用 EdgeOne 平台模型网关（推荐，赠送 50 万 Token）
#   请先在 EdgeOne 控制台 → Models 页面配置厂商 API Key
AI_GATEWAY_BASE_URL=https://api.edgeone.ai/v1
AI_GATEWAY_API_KEY=your-gateway-api-key

# 方式二：直调厂商 API（绕过平台网关）
#   设置 AI_GATEWAY_BASE_URL 和 AI_GATEWAY_API_KEY 为厂商原生地址
#   示例：
#   AI_GATEWAY_BASE_URL=https://api.deepseek.com
#   AI_GATEWAY_API_KEY=sk-your-deepseek-key
#   DEEPSEEK_API_KEY=sk-your-deepseek-key  # 兼容旧配置

# AI 模型名称（可在管理后台动态切换）
# 默认 deepseek-chat，可用模型请参考 EdgeOne Models 页面
AI_MODEL=deepseek-chat

# ==================== 存储配置 ====================

# EdgeOne KV 命名空间
# 用于存储：用户、对话、消息、定时任务、执行记录、系统设置
KV_NAMESPACE=ai-assistant-kv

# ==================== 定时任务配置 ====================

# 通知邮箱（定时任务执行结果发送到此邮箱）
NOTIFICATION_EMAIL=admin@example.com

# 全局默认超时时间（毫秒）
# 影响：浏览器操作、代码执行等任务的超时限制
DEFAULT_TIMEOUT_MS=30000

# 定时任务扫描间隔（秒）
# 关联：edgeone.json schedules.cron（当前每分钟触发）
# 建议 30-300 秒之间
CRON_SCAN_INTERVAL=60

# ==================== edgeone.json 新增配置说明 ====================
# 以下配置在 edgeone.json 中设置，不在 .env 中
#
# agents.framework: "openai"
#   - 声明 Agent 框架类型（openai / openai-agents-sdk / langgraph / crewai）
#   - 决定 context.store 和 context.tools 的适配形态
#   - 本项目使用 OpenAI 兼容格式，设为 "openai"
#
# agents.timeout: 300
#   - Agent 单次任务执行的最大秒数
#   - 浏览器自动化操作建议 300 秒以上
#
# agents.sandbox.timeout: 600
#   - 沙箱实例存活时长（秒）
#   - 同一 conversation_id 的请求共享沙箱
#   - 超时后沙箱自动销毁释放资源
#
# 完整配置示例：
# {
#   "agents": {
#     "dir": "agents",
#     "framework": "openai",
#     "timeout": 300,
#     "sandbox": { "timeout": 600 }
#   }
# }
# ============================================
